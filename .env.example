# Application
F1_APP_NAME=F1 Telemetry
F1_ENVIRONMENT=development
F1_LOG_LEVEL=INFO

# API
F1_API_HOST=0.0.0.0
F1_API_PORT=8000
F1_WEB_ORIGIN=http://localhost:3000

# Worker
F1_WORKER_POLL_INTERVAL_SECONDS=5

# PostgreSQL
POSTGRES_DB=f1telemetry
POSTGRES_USER=f1telemetry
POSTGRES_PASSWORD=f1telemetry_dev
POSTGRES_PORT=5432
F1_DATABASE_URL=postgresql+psycopg://f1telemetry:f1telemetry_dev@localhost:5432/f1telemetry

# Redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_dev
F1_REDIS_URL=redis://:redis_dev@localhost:6379/0

# Frontend
FRONTEND_PORT=3000

# Browser-visible frontend configuration
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
